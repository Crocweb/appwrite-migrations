{
  "name": "@crocweb/appwrite-migrations",
  "version": "1.0.1",
  "description": "Moteur de migrations Appwrite versionnées, forward-only et idempotent",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crocweb/appwrite-migrations.git"
  },
  "homepage": "https://github.com/Crocweb/appwrite-migrations#readme",
  "bugs": "https://github.com/Crocweb/appwrite-migrations/issues",
  "keywords": ["appwrite", "migrations", "schema", "tablesdb"],
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "node-appwrite": ">=22"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "node-appwrite": "^22.1.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
